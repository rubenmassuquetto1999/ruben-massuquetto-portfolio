RewriteEngine On

# 1. Redirecionar /index.html para /home (ou para a raiz /)
RewriteRule ^index\.html$ /home [R=301,L]
RewriteRule ^home$ index.html [L]

# 2. Remover a extensão .html das outras URLs
# Se o usuário digitar /projetos.html, redireciona para /projetos
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# Se o usuário acessar /projetos, o servidor serve o arquivo projetos.html internamente
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]